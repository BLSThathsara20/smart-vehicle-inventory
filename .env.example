# Firebase (Authentication) — Project Settings in Firebase Console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Sanity — Project ID, dataset, API version, and a token with Editor permissions (browser exposes this; use a restricted token in production)
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01
VITE_SANITY_TOKEN=

# ImgBB — https://api.imgbb.com/ (upload key; never commit the real key)
VITE_IMGBB_API_KEY=
